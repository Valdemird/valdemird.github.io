# Local authoring secrets. Copy to .env (which is gitignored).
#
# Required by scripts/blog/generate-image.mjs (the /blog-image slash command).
# Get a key at platform.openai.com/api-keys — must be an API key for an
# organization that has completed API Organization Verification, since
# gpt-image-2 requires verified orgs.
OPENAI_API_KEY=sk-your-key-here
