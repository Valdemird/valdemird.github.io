---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import ReadingProgress from '../components/blog/ReadingProgress.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, tags, lang = 'en' } = Astro.props;

// Build hreflang alternates for this post
const allPosts = await getCollection('blog');
const currentPath = Astro.url.pathname;
const slug = currentPath.replace(/^\/blog\//, '').replace(/\/$/, '');

// OG image: use heroImage if provided, otherwise use generated OG image
const ogImage = heroImage || `/og/${slug}.png`;

// Build JSON-LD BlogPosting structured data
const blogPostingJsonLd: Record<string, unknown> = {
	'@context': 'https://schema.org',
	'@type': 'BlogPosting',
	headline: title,
	description,
	datePublished: pubDate.toISOString(),
	...(updatedDate && { dateModified: updatedDate.toISOString() }),
	author: {
		'@type': 'Person',
		name: 'Valdemir D.',
		url: 'https://valdemird.com',
	},
	publisher: {
		'@type': 'Person',
		name: 'Valdemir D.',
		url: 'https://valdemird.com',
	},
	mainEntityOfPage: {
		'@type': 'WebPage',
		'@id': `https://valdemird.com${currentPath}`,
	},
	inLanguage: lang,
	...(heroImage && { image: `https://valdemird.com${heroImage}` }),
	...(tags && tags.length > 0 && { keywords: tags.join(', ') }),
};

const alternates: { hreflang: string; href: string }[] = [];
if (lang === 'en') {
	// Look for ES counterpart: es/<slug>
	const esPair = allPosts.find(p => p.id === `es/${slug}` && p.data.lang === 'es');
	if (esPair) {
		alternates.push(
			{ hreflang: 'en', href: `https://valdemird.com/blog/${slug}/` },
			{ hreflang: 'es', href: `https://valdemird.com/blog/es/${slug}/` },
		);
	}
} else if (lang === 'es') {
	// Look for EN counterpart: <slug without es/>
	const enSlug = slug.replace(/^es\//, '');
	const enPair = allPosts.find(p => p.id === enSlug && p.data.lang === 'en');
	if (enPair) {
		alternates.push(
			{ hreflang: 'en', href: `https://valdemird.com/blog/${enSlug}/` },
			{ hreflang: 'es', href: `https://valdemird.com/blog/es/${enSlug}/` },
		);
	}
}
---

<html lang={lang}>
	<head>
		<BaseHead title={title} description={description} image={ogImage} lang={lang} type="article" alternates={alternates} jsonLd={blogPostingJsonLd} publishedTime={pubDate} modifiedTime={updatedDate} tags={tags} />
	</head>

	<body>
		<ReadingProgress />
		<Header />
		<main>
			<article>
				{heroImage && (
					<div class="hero-image">
						<img width={1020} height={510} src={heroImage} alt="" />
					</div>
				)}
				<div class="prose">
					<header class="article-header">
						<div class="meta">
							<FormattedDate date={pubDate} locale={lang} />
							{updatedDate && (
								<span class="updated">
									&middot; updated <FormattedDate date={updatedDate} locale={lang} />
								</span>
							)}
						</div>
						<h1>{title}</h1>
						{description && <p class="lead">{description}</p>}
						{tags && tags.length > 0 && (
							<div class="article-tags">
								{tags.map((tag: string) => <span class="tag">{tag}</span>)}
							</div>
						)}
						<hr />
					</header>
					<div class="article-body">
						<slot />
					</div>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 100%;
		margin: 0;
		padding: 0;
	}

	article {
		padding-bottom: var(--space-2xl);
	}

	.hero-image {
		max-width: var(--wide-width);
		margin: var(--space-lg) auto;
		padding: 0 var(--space-lg);
	}

	.hero-image img {
		width: 100%;
		border-radius: var(--radius-lg);
		box-shadow: var(--shadow-lg);
	}

	.prose {
		max-width: var(--content-width);
		margin: 0 auto;
		padding: var(--space-lg);
	}

	/* --- Article Header --- */
	.article-header {
		margin-bottom: var(--space-xl);
		text-align: center;
	}

	.article-header h1 {
		margin: 0.4em 0 0.3em;
		font-size: clamp(2rem, 5vw, 2.8rem);
		line-height: 1.15;
		letter-spacing: -0.02em;
	}

	.meta {
		font-size: 0.88rem;
		color: var(--color-text-muted);
		font-family: var(--font-sans);
	}

	.updated {
		color: var(--color-text-muted);
	}

	.lead {
		font-size: 1.2rem;
		color: var(--color-text-secondary);
		line-height: 1.6;
		max-width: 540px;
		margin: 0 auto 1em;
	}

	.article-tags {
		display: flex;
		justify-content: center;
		flex-wrap: wrap;
		gap: 0.4rem;
		margin-top: 0.75em;
	}

	.tag {
		font-size: 0.75rem;
		font-weight: 500;
		padding: 0.2em 0.65em;
		background: var(--color-accent-subtle);
		border-radius: var(--radius-sm);
		color: var(--color-accent);
	}

	.article-header hr {
		margin-top: var(--space-xl);
	}

	/* --- Article Body: editorial typography --- */
	.article-body {
		font-size: 1.1rem;
		line-height: 1.85;
		color: var(--color-text-secondary);
	}

	.article-body :global(h2) {
		font-family: var(--font-serif);
		font-size: 1.6rem;
		margin-top: 2.5em;
		margin-bottom: 0.6em;
		color: var(--color-text);
		letter-spacing: -0.01em;
	}

	.article-body :global(h3) {
		font-family: var(--font-serif);
		font-size: 1.3rem;
		margin-top: 2em;
		margin-bottom: 0.5em;
		color: var(--color-text);
	}

	.article-body :global(h4) {
		font-family: var(--font-sans);
		font-size: 1.1rem;
		font-weight: 600;
		margin-top: 1.5em;
		margin-bottom: 0.4em;
		color: var(--color-text);
	}

	.article-body :global(p) {
		margin-bottom: 1.6em;
	}

	.article-body :global(ul),
	.article-body :global(ol) {
		padding-left: 1.25em;
		margin-bottom: 1.6em;
	}

	.article-body :global(li) {
		margin-bottom: 0.4em;
	}

	.article-body :global(blockquote) {
		border-left: 3px solid var(--color-accent);
		padding: 0.25em 0 0.25em 1.5em;
		margin: 2em 0;
		font-style: italic;
		color: var(--color-text-secondary);
	}

	.article-body :global(blockquote p) {
		margin-bottom: 0.5em;
	}

	.article-body :global(img) {
		border-radius: var(--radius-md);
		box-shadow: var(--shadow-md);
		margin: 1.5em 0;
	}

	.article-body :global(hr) {
		margin: 2.5em 0;
	}

	.article-body :global(a) {
		text-decoration-color: var(--color-accent);
		text-decoration-thickness: 1px;
		text-underline-offset: 3px;
	}

	.article-body :global(strong) {
		color: var(--color-text);
	}

	/* Code in prose */
	.article-body :global(code) {
		font-size: 0.88em;
	}

	.article-body :global(pre) {
		font-size: 0.88rem;
		margin: 1.75em 0;
	}

	@media (max-width: 768px) {
		.article-body {
			font-size: 1rem;
		}

		.article-header h1 {
			font-size: 1.8rem;
		}
	}
</style>
