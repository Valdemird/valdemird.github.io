---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ProjectCard from '../components/ProjectCard.astro';
import PostPreview from '../components/PostPreview.astro';
import { SITE_TITLE, SITE_DESCRIPTION, PROJECTS, SOCIAL_LINKS, t } from '../consts';
import { getCollection } from 'astro:content';

const strings = t(Astro.url);

const recentPosts = (await getCollection('blog'))
	.filter((p) => p.data.lang === 'en')
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);

const techStack = ['TypeScript', 'React', 'Next.js', 'Astro', 'Node.js', 'Prisma', 'Tailwind CSS', 'PostgreSQL', 'Vercel AI SDK', 'Claude Code'];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} alternates={[
			{ hreflang: 'en', href: 'https://valdemird.com/' },
			{ hreflang: 'es', href: 'https://valdemird.com/es/' },
		]} />
	</head>
	<body>
		<Header />
		<main>
			<!-- Hero with gradient orbs -->
			<section class="hero" id="hero">
				<!-- Animated gradient background -->
				<div class="hero-bg" aria-hidden="true">
					<div class="orb orb-1"></div>
					<div class="orb orb-2"></div>
					<div class="orb orb-3"></div>
					<div class="grid-pattern"></div>
				</div>

				<div class="hero-inner">
					<div class="hero-content">
						<div class="status-badge animate-fade-in">
							<span class="status-dot"></span>
							<span>Available for interesting projects</span>
						</div>
						<h1 class="animate-fade-in delay-1">{strings.home.name}</h1>
						<p class="subtitle animate-fade-in delay-2">{strings.home.subtitle}</p>
						<p class="bio animate-fade-in delay-3">{strings.home.bio}</p>
						<div class="hero-links animate-fade-in delay-4">
							{SOCIAL_LINKS.github && (
								<a href={SOCIAL_LINKS.github} target="_blank" rel="noopener noreferrer" class="hero-link">
									<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
										<path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
									</svg>
									GitHub
								</a>
							)}
							{SOCIAL_LINKS.linkedin && (
								<a href={SOCIAL_LINKS.linkedin} target="_blank" rel="noopener noreferrer" class="hero-link">
									<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
										<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
									</svg>
									LinkedIn
								</a>
							)}
						</div>
					</div>

					<!-- Interactive floating terminal -->
					<div class="hero-visual" id="hero-visual" aria-hidden="true">
						<div class="floating-terminal" id="floating-terminal">
							<div class="terminal-header">
								<div class="terminal-dots">
									<span></span><span></span><span></span>
								</div>
								<span class="terminal-title">~/projects</span>
							</div>
							<div class="terminal-body">
								<div class="terminal-line">
									<span class="terminal-prompt">$</span>
									<span class="terminal-cmd" id="typed-cmd"></span>
									<span class="terminal-cursor">|</span>
								</div>
								<div class="terminal-output" id="terminal-output"></div>
							</div>
						</div>
						<div class="float-shape shape-1" id="shape-1"></div>
						<div class="float-shape shape-2" id="shape-2"></div>
						<div class="float-shape shape-3" id="shape-3"></div>
					</div>
				</div>
			</section>

			<!-- Scrolling tech marquee -->
			<div class="marquee-wrapper" aria-hidden="true">
				<div class="marquee-track">
					{[...techStack, ...techStack].map((tech) => (
						<span class="marquee-item">
							<span class="marquee-dot"></span>
							{tech}
						</span>
					))}
				</div>
			</div>

			<!-- Projects -->
			<section class="section projects-section" id="projects">
				<div class="section-header">
					<span class="section-label">01</span>
					<h2>{strings.home.projectsTitle}</h2>
					<div class="section-line"></div>
				</div>
				<div class="projects-grid">
					{PROJECTS.map((project) => (
						<ProjectCard
							title={project.title}
							description={project.description}
							url={project.url}
							tech={project.tech}
						/>
					))}
				</div>
			</section>

			<!-- Recent Posts -->
			{recentPosts.length > 0 && (
				<section class="section posts-section" id="posts">
					<div class="section-header">
						<span class="section-label">02</span>
						<h2>{strings.home.recentPostsTitle}</h2>
						<div class="section-line"></div>
					</div>
					<div class="posts-list">
						{recentPosts.map((post) => (
							<PostPreview
								id={post.id}
								title={post.data.title}
								description={post.data.description}
								pubDate={post.data.pubDate}
								tags={post.data.tags}
								locale="en"
							/>
						))}
					</div>
					<div class="view-all">
						<a href="/blog/">{strings.home.viewAllPosts} &rarr;</a>
					</div>
				</section>
			)}
		</main>
		<Footer />
	</body>
</html>

<script>
	// --- Mouse-tracking parallax ---
	const hero = document.getElementById('hero');
	const terminal = document.getElementById('floating-terminal');
	const shape1 = document.getElementById('shape-1');
	const shape2 = document.getElementById('shape-2');
	const shape3 = document.getElementById('shape-3');
	let mouseX = 0, mouseY = 0, currentX = 0, currentY = 0;

	function lerp(a: number, b: number, t: number) { return a + (b - a) * t; }

	hero?.addEventListener('mousemove', (e) => {
		const rect = hero.getBoundingClientRect();
		mouseX = ((e.clientX - rect.left) / rect.width - 0.5) * 2;
		mouseY = ((e.clientY - rect.top) / rect.height - 0.5) * 2;
	});
	hero?.addEventListener('mouseleave', () => { mouseX = 0; mouseY = 0; });

	function animateParallax() {
		currentX = lerp(currentX, mouseX, 0.06);
		currentY = lerp(currentY, mouseY, 0.06);
		if (terminal) terminal.style.transform = `translate(${currentX * 14}px, ${currentY * 10}px) rotateY(${currentX * 3}deg) rotateX(${-currentY * 3}deg)`;
		if (shape1) shape1.style.transform = `translate(${currentX * -22}px, ${currentY * -18}px)`;
		if (shape2) shape2.style.transform = `translate(${currentX * 28}px, ${currentY * 20}px)`;
		if (shape3) shape3.style.transform = `translate(${currentX * -18}px, ${currentY * 25}px)`;
		requestAnimationFrame(animateParallax);
	}
	animateParallax();

	// --- Terminal typing ---
	const commands = [
		{ cmd: '/spec-create auth-jwt', output: '  Creating spec... done\n  Saved to .claude/specs/auth-jwt.md' },
		{ cmd: '/spec-audit auth-jwt', output: '  Analyzing codebase... 47 files\n  Enriched spec with technical context' },
		{ cmd: '/spec-plan auth-jwt', output: '  Generated 3-phase plan\n  Ready for implementation' },
	];
	const cmdEl = document.getElementById('typed-cmd');
	const outputEl = document.getElementById('terminal-output');
	const cursorEl = document.querySelector('.terminal-cursor') as HTMLElement;
	let cmdIndex = 0;
	let _terminalStopped = false;

	async function sleep(ms: number) { return new Promise(r => setTimeout(r, ms)); }

	function waitForVisible(): Promise<void> {
		if (!document.hidden) return Promise.resolve();
		return new Promise(resolve => {
			const handler = () => {
				if (!document.hidden) {
					document.removeEventListener('visibilitychange', handler);
					resolve();
				}
			};
			document.addEventListener('visibilitychange', handler);
		});
	}

	async function typeCommand(text: string) {
		if (!cmdEl) return;
		cmdEl.textContent = '';
		for (let i = 0; i < text.length; i++) {
			if (_terminalStopped) return;
			await waitForVisible();
			cmdEl.textContent += text[i];
			await sleep(45 + Math.random() * 35);
		}
	}
	async function showOutput(text: string) {
		if (!outputEl) return;
		await sleep(300);
		if (cursorEl) cursorEl.style.display = 'none';
		for (const line of text.split('\n')) {
			if (_terminalStopped) return;
			await waitForVisible();
			const div = document.createElement('div');
			div.className = 'output-line';
			div.textContent = line;
			outputEl.appendChild(div);
			await sleep(150);
		}
	}
	async function runTerminalLoop() {
		while (!_terminalStopped) {
			await waitForVisible();
			const { cmd, output } = commands[cmdIndex % commands.length];
			if (cmdEl) cmdEl.textContent = '';
			if (outputEl) outputEl.innerHTML = '';
			if (cursorEl) cursorEl.style.display = '';
			await sleep(800); await typeCommand(cmd); await showOutput(output); await sleep(2500);
			cmdIndex++;
		}
	}
	runTerminalLoop();

	// --- Intersection Observer ---
	const observer = new IntersectionObserver(
		(entries) => { entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); } }); },
		{ threshold: 0.08, rootMargin: '0px 0px -60px 0px' }
	);
	document.querySelectorAll('.section').forEach(s => observer.observe(s));

	// --- Cleanup on View Transition ---
	document.addEventListener('astro:before-swap', () => {
		_terminalStopped = true;
		observer.disconnect();
	}, { once: true });
</script>

<style>
	main {
		max-width: var(--full-width);
		margin: 0 auto;
		padding: 0;
		overflow-x: hidden;
		overflow-y: hidden;
	}

	/* ========================================
	   HERO
	   ======================================== */
	.hero {
		position: relative;
		min-height: 85vh;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 6rem var(--space-lg) 4rem;
		perspective: 900px;
		overflow: hidden;
	}

	/* Animated gradient orbs */
	.hero-bg {
		position: absolute;
		inset: 0;
		overflow: hidden;
		z-index: 0;
	}

	.orb {
		position: absolute;
		border-radius: 50%;
		filter: blur(80px);
		opacity: 0.12;
		animation: orbFloat 20s ease-in-out infinite;
	}

	.orb-1 {
		width: 500px;
		height: 500px;
		top: -10%;
		right: -5%;
		background: var(--color-accent);
		animation-duration: 18s;
	}

	.orb-2 {
		width: 400px;
		height: 400px;
		bottom: -15%;
		left: -10%;
		background: var(--color-success);
		animation-duration: 22s;
		animation-delay: -5s;
	}

	.orb-3 {
		width: 300px;
		height: 300px;
		top: 40%;
		left: 50%;
		background: var(--color-warning);
		animation-duration: 25s;
		animation-delay: -10s;
		opacity: 0.08;
	}

	@keyframes orbFloat {
		0%, 100% { transform: translate(0, 0) scale(1); }
		33% { transform: translate(30px, -20px) scale(1.05); }
		66% { transform: translate(-20px, 15px) scale(0.95); }
	}

	/* Subtle grid pattern */
	.grid-pattern {
		position: absolute;
		inset: 0;
		background-image:
			linear-gradient(var(--color-border) 1px, transparent 1px),
			linear-gradient(90deg, var(--color-border) 1px, transparent 1px);
		background-size: 60px 60px;
		opacity: 0.3;
		mask-image: radial-gradient(ellipse 60% 60% at 50% 40%, black 20%, transparent 70%);
		-webkit-mask-image: radial-gradient(ellipse 60% 60% at 50% 40%, black 20%, transparent 70%);
	}

	.hero-inner {
		position: relative;
		z-index: 1;
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: var(--wide-width);
		width: 100%;
		gap: 4rem;
	}

	.hero-content {
		max-width: 520px;
		flex-shrink: 0;
	}

	.status-badge {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.4rem 0.9rem;
		font-size: 0.76rem;
		font-weight: 500;
		color: var(--color-success);
		background: oklch(from var(--color-success) l c h / 0.08);
		border: 1px solid oklch(from var(--color-success) l c h / 0.15);
		border-radius: 100px;
		margin-bottom: 2rem;
		letter-spacing: 0.02em;
	}

	.status-dot {
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: var(--color-success);
		animation: pulseDot 2s ease-in-out infinite;
	}

	@keyframes pulseDot {
		0%, 100% { opacity: 1; box-shadow: 0 0 0 0 oklch(from var(--color-success) l c h / 0.4); }
		50% { opacity: 0.8; box-shadow: 0 0 0 4px oklch(from var(--color-success) l c h / 0); }
	}

	.hero h1 {
		font-size: clamp(3.2rem, 8vw, 5.5rem);
		margin-bottom: 0.2em;
		line-height: 0.95;
		letter-spacing: -0.04em;
		color: var(--color-text);
	}

	.subtitle {
		font-family: var(--font-sans);
		font-size: 1.15rem;
		color: var(--color-accent);
		font-weight: 500;
		margin-bottom: 1.5em;
		letter-spacing: 0.01em;
	}

	.bio {
		font-size: 1.05rem;
		line-height: 1.8;
		color: var(--color-text-secondary);
		max-width: 440px;
	}

	.hero-links {
		display: flex;
		gap: 0.6rem;
		margin-top: 2rem;
	}

	.hero-link {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		padding: 0.55rem 1.1rem;
		font-size: 0.85rem;
		font-weight: 500;
		color: var(--color-text-secondary);
		text-decoration: none;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		background: oklch(from var(--color-surface) l c h / 0.6);
		backdrop-filter: blur(8px);
		-webkit-backdrop-filter: blur(8px);
		transition: all var(--duration-normal) var(--ease-spring);
	}

	.hero-link:hover {
		color: var(--color-text);
		border-color: var(--color-border-strong);
		background: var(--color-surface);
		box-shadow: var(--shadow-md);
		transform: translateY(-2px);
	}

	/* ========================================
	   FLOATING TERMINAL
	   ======================================== */
	.hero-visual {
		position: relative;
		flex-shrink: 0;
		width: 400px;
		height: 290px;
	}

	.floating-terminal {
		position: relative;
		width: 100%;
		border-radius: var(--radius-lg);
		border: 1px solid var(--color-border);
		background: oklch(from var(--color-surface) l c h / 0.8);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		box-shadow: var(--shadow-xl);
		overflow: hidden;
		z-index: 2;
		transition: transform 0.1s linear;
		will-change: transform;
		animation: terminalEnter 0.8s var(--ease-smooth) 0.3s both;
	}

	@keyframes terminalEnter {
		from { opacity: 0; transform: translateY(24px) scale(0.94); }
		to { opacity: 1; transform: translateY(0) scale(1); }
	}

	.terminal-header {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		padding: 0.65rem 1rem;
		border-bottom: 1px solid var(--color-border);
		background: oklch(from var(--color-bg-secondary) l c h / 0.5);
	}

	.terminal-dots { display: flex; gap: 5px; }
	.terminal-dots span { width: 10px; height: 10px; border-radius: 50%; }
	.terminal-dots span:first-child { background: oklch(0.65 0.2 27); }
	.terminal-dots span:nth-child(2) { background: oklch(0.78 0.15 85); }
	.terminal-dots span:last-child { background: oklch(0.6 0.18 145); }

	.terminal-title {
		font-family: var(--font-mono);
		font-size: 0.72rem;
		color: var(--color-text-muted);
	}

	.terminal-body {
		padding: 1.1rem 1.25rem;
		font-family: var(--font-mono);
		font-size: 0.82rem;
		line-height: 1.6;
		min-height: 170px;
	}

	.terminal-line { display: flex; align-items: center; gap: 0.5rem; }
	.terminal-prompt { color: var(--color-accent); font-weight: 600; }
	.terminal-cmd { color: var(--color-text); }
	.terminal-cursor { color: var(--color-accent); animation: blink 1s step-end infinite; font-weight: 300; }
	@keyframes blink { 50% { opacity: 0; } }

	.terminal-output { margin-top: 0.5rem; }
	.terminal-output :global(.output-line) {
		color: var(--color-text-muted);
		font-size: 0.78rem;
		animation: lineIn 0.3s var(--ease-smooth) both;
	}
	@keyframes lineIn { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; transform: translateY(0); } }

	/* Floating accent shapes */
	.float-shape {
		position: absolute;
		border-radius: 50%;
		z-index: 1;
		transition: transform 0.15s linear;
		will-change: transform;
	}

	.shape-1 {
		width: 90px; height: 90px; top: -25px; right: -30px;
		background: oklch(from var(--color-accent) l c h / 0.1);
		border: 1px solid oklch(from var(--color-accent) l c h / 0.15);
		animation: floatA 6s ease-in-out infinite;
	}

	.shape-2 {
		width: 50px; height: 50px; bottom: 15px; left: -20px;
		background: oklch(from var(--color-success) l c h / 0.12);
		border: 1px solid oklch(from var(--color-success) l c h / 0.18);
		animation: floatB 8s ease-in-out infinite;
	}

	.shape-3 {
		width: 28px; height: 28px; top: 55%; right: -40px;
		background: oklch(from var(--color-warning) l c h / 0.12);
		border: 1px solid oklch(from var(--color-warning) l c h / 0.18);
		animation: floatC 7s ease-in-out infinite;
	}

	@keyframes floatA { 0%, 100% { transform: translate(0, 0); } 50% { transform: translate(-8px, 12px); } }
	@keyframes floatB { 0%, 100% { transform: translate(0, 0); } 50% { transform: translate(10px, -8px); } }
	@keyframes floatC { 0%, 100% { transform: translate(0, 0); } 50% { transform: translate(-6px, -10px); } }

	/* ========================================
	   TECH MARQUEE
	   ======================================== */
	.marquee-wrapper {
		padding: 1.5rem 0;
		border-top: 1px solid var(--color-border);
		border-bottom: 1px solid var(--color-border);
		overflow: hidden;
		mask-image: linear-gradient(90deg, transparent, black 10%, black 90%, transparent);
		-webkit-mask-image: linear-gradient(90deg, transparent, black 10%, black 90%, transparent);
	}

	.marquee-track {
		display: flex;
		gap: 2.5rem;
		width: max-content;
		animation: marqueeScroll 30s linear infinite;
	}

	.marquee-item {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		font-family: var(--font-mono);
		font-size: 0.78rem;
		font-weight: 450;
		color: var(--color-text-muted);
		white-space: nowrap;
		letter-spacing: 0.02em;
	}

	.marquee-dot {
		width: 4px;
		height: 4px;
		border-radius: 50%;
		background: var(--color-accent);
		opacity: 0.5;
	}

	@keyframes marqueeScroll {
		from { transform: translateX(0); }
		to { transform: translateX(-50%); }
	}

	/* ========================================
	   SECTIONS
	   ======================================== */
	.section {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: 5rem var(--space-lg);
		opacity: 0;
		transform: translateY(24px);
		transition: opacity 0.7s var(--ease-smooth),
			transform 0.7s var(--ease-smooth);
	}

	.section.visible {
		opacity: 1;
		transform: translateY(0);
	}

	.section-header {
		display: flex;
		align-items: center;
		gap: var(--space-md);
		margin-bottom: 2.5rem;
	}

	.section-label {
		font-family: var(--font-mono);
		font-size: 0.75rem;
		font-weight: 500;
		color: var(--color-accent);
		opacity: 0.6;
		letter-spacing: 0.05em;
	}

	.section-header h2 {
		font-size: 1.5rem;
		margin: 0;
		white-space: nowrap;
