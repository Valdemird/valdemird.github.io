---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SOCIAL_LINKS, t } from '../../consts';

const strings = t(Astro.url);
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={`${strings.about.title} — ${SITE_TITLE}`} description={strings.about.description} />
	</head>
	<body>
		<Header />
		<main>
			<div class="about-hero">
				<div class="about-hero-bg" aria-hidden="true"><div class="hero-grid"></div></div>
				<div class="about-hero-content animate-fade-in">
					<span class="about-label">Acerca</span>
					<h1>{strings.about.title}</h1>
				</div>
			</div>
			<article class="about-body">
				<section class="section animate-fade-in delay-1">
					<p>Soy ingeniero de software y me encanta construir herramientas que hacen a los desarrolladores más productivos. Me apasiona la intersección entre la IA y la experiencia de desarrollo — cómo podemos usar modelos de lenguaje no solo como generadores de código, sino como colaboradores reflexivos en el proceso de desarrollo de software.</p>
					<p>Actualmente estoy construyendo <a href="https://todo.valdemird.com">todo.valdemird.com</a>, un gestor de tareas con IA, temporizador Pomodoro, drag-and-drop y planificación inteligente. Construido con Next.js 15, React 19, Prisma y Tailwind CSS 4.</p>
				</section>
				<section class="section">
					<div class="section-header">
						<span class="section-label">01</span>
						<h2>En lo que creo</h2>
						<div class="section-line"></div>
					</div>
					<div class="beliefs">
						<div class="belief"><div class="belief-number" aria-hidden="true">01</div><h3>Desarrollo basado en especificaciones</h3><p>Escribe el spec antes del código. Deja que el LLM sea tu co-arquitecto, no solo tu mecanógrafo.</p></div>
						<div class="belief"><div class="belief-number" aria-hidden="true">02</div><h3>Construir en público</h3><p>Comparte lo que aprendes. La mejor forma de solidificar el conocimiento es enseñarlo.</p></div>
						<div class="belief"><div class="belief-number" aria-hidden="true">03</div><h3>Belleza y función</h3><p>Las herramientas deben ser hermosas Y funcionales. El diseño no es decoración — es comunicación.</p></div>
					</div>
				</section>
				<section class="section">
					<div class="section-header">
						<span class="section-label">02</span>
						<h2>Contacto</h2>
						<div class="section-line"></div>
					</div>
					<div class="contact-links">
						{SOCIAL_LINKS.github && (<a href={SOCIAL_LINKS.github} target="_blank" rel="noopener noreferrer" class="contact-link"><svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg><span>GitHub</span></a>)}
						{SOCIAL_LINKS.linkedin && (<a href={SOCIAL_LINKS.linkedin} target="_blank" rel="noopener noreferrer" class="contact-link"><svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg><span>LinkedIn</span></a>)}
					</div>
				</section>
			</article>
		</main>

		<script>
			function initAbout() {
				const observer = new IntersectionObserver(
					(entries) => { entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); } }); },
					{ threshold: 0.08, rootMargin: '0px 0px -60px 0px' }
				);
				document.querySelectorAll('.section:not(.animate-fade-in)').forEach(s => observer.observe(s));
			}
			initAbout();
			document.addEventListener('astro:after-swap', initAbout);
		</script>

		<Footer />
	</body>
</html>

<style>
	main{max-width:var(--full-width);margin:0 auto;padding:0}
	.about-hero{position:relative;padding:5rem var(--space-lg) 3rem;overflow:hidden}.about-hero-bg{position:absolute;inset:0;z-index:0}
	.hero-grid{position:absolute;inset:0;background-image:linear-gradient(var(--color-border) 1px,transparent 1px),linear-gradient(90deg,var(--color-border) 1px,transparent 1px);background-size:48px 48px;opacity:.25;mask-image:radial-gradient(ellipse 70% 80% at 50% 60%,black 10%,transparent 70%);-webkit-mask-image:radial-gradient(ellipse 70% 80% at 50% 60%,black 10%,transparent 70%)}
	.about-hero-content{position:relative;z-index:1;max-width:var(--content-width);margin:0 auto}
	.about-label{font-family:var(--font-mono);font-size:.75rem;font-weight:500;color:var(--color-accent);letter-spacing:.08em;text-transform:uppercase;display:block;margin-bottom:.75rem}
	.about-hero-content h1{font-size:clamp(2rem,5vw,2.8rem)}
	.about-body{max-width:var(--content-width);margin:0 auto;padding:0 var(--space-lg) 4rem}
	.about-body p{font-size:1.1rem;line-height:1.85}
	.section{margin-bottom:3.5rem;opacity:0;transform:translateY(24px);transition:opacity .7s var(--ease-smooth),transform .7s var(--ease-smooth)}
	.section.visible,.section.animate-fade-in{opacity:1;transform:translateY(0)}
	.section-header{display:flex;align-items:center;gap:var(--space-md);margin-bottom:2rem}
	.section-label{font-family:var(--font-mono);font-size:.75rem;font-weight:500;color:var(--color-accent);opacity:.6;letter-spacing:.05em}
	.section-header h2{margin:0;white-space:nowrap}.section-line{flex:1;height:1px;background:linear-gradient(90deg,var(--color-border),transparent)}
	.beliefs{display:grid;gap:1rem}
	.belief{position:relative;padding:1.5rem 1.5rem 1.5rem 4.5rem;border:1px solid var(--color-border);border-radius:var(--radius-md);background:var(--color-surface);transition:border-color var(--duration-normal) var(--ease-smooth),transform var(--duration-normal) var(--ease-spring),box-shadow var(--duration-normal) var(--ease-smooth)}
	.belief:hover{border-color:var(--color-accent);transform:translateX(4px);box-shadow:var(--shadow-md)}
	.belief-number{position:absolute;left:1.25rem;top:1.5rem;font-family:var(--font-mono);font-size:.72rem;font-weight:600;color:var(--color-accent);opacity:.5}
	.belief h3{font-size:1.05rem;margin-bottom:.25em}.belief p{font-size:.92rem;margin:0;color:var(--color-text-secondary);line-height:1.6}
	.contact-links{display:flex;gap:.75rem;margin-top:1rem}
	.contact-link{display:inline-flex;align-items:center;gap:.5rem;padding:.6rem 1.2rem;font-size:.88rem;font-weight:500;color:var(--color-text-secondary);text-decoration:none;border:1px solid var(--color-border);border-radius:var(--radius-md);transition:all var(--duration-normal) var(--ease-spring)}
	.contact-link:hover{color:var(--color-text);border-color:var(--color-accent);background:var(--color-accent-subtle);transform:translateY(-2px);box-shadow:var(--shadow-md)}
	@media(max-width:640px){.about-hero{padding:3rem var(--space-lg) 2rem}.belief{padding-left:1.5rem}.belief-number{display:none}.contact-links{flex-direction:column}}
</style>
