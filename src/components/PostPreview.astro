---
import FormattedDate from './FormattedDate.astro';

interface Props {
	id: string;
	title: string;
	description: string;
	pubDate: Date;
	tags?: string[];
	basePath?: string;
	locale?: string;
	enableTransition?: boolean;
}

const { id, title, description, pubDate, tags, basePath = '/blog', locale = 'en', enableTransition = false } = Astro.props;
const readingTime = Math.max(1, Math.ceil(description.length / 50));
---

<a href={`${basePath}/${id}/`} class="post-preview">
	<div class="post-accent" aria-hidden="true"></div>
	<div class="post-preview-content">
		<div class="post-preview-meta">
			<FormattedDate date={pubDate} locale={locale} />
			<span class="separator">&middot;</span>
			<span>{readingTime} min</span>
		</div>
		{enableTransition ? (
			<h3 transition:name={`post-title-${id.replace(/\//g, '-')}`}>{title}</h3>
		) : (
			<h3 data-vt-name={`post-title-${id.replace(/\//g, '-')}`}>{title}</h3>
		)}
		<p>{description}</p>
		{tags && tags.length > 0 && (
			<div class="post-preview-tags">
				{tags.map((tag) => <span class="tag">{tag}</span>)}
			</div>
		)}
	</div>
	<svg class="post-arrow" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
		<line x1="5" y1="12" x2="19" y2="12"></line>
		<polyline points="12 5 19 12 12 19"></polyline>
	</svg>
</a>

<style>
	.post-preview {
		position: relative;
		display: flex;
		align-items: center;
		gap: var(--space-lg);
		padding: 1.25rem var(--space-lg);
		text-decoration: none;
		color: inherit;
		border-radius: var(--radius-lg);
		border: 1px solid transparent;
		transition: border-color var(--duration-normal) var(--ease-smooth),
			background var(--duration-normal) var(--ease-smooth),
			transform var(--duration-normal) var(--ease-spring);
	}

	.post-accent {
		position: absolute;
		left: 0;
		top: 50%;
		transform: translateY(-50%);
		width: 3px;
		height: 0;
		background: var(--color-accent);
		border-radius: 2px;
		transition: height var(--duration-normal) var(--ease-spring);
	}

	.post-preview:hover {
		border-color: var(--color-border);
		background: oklch(from var(--color-surface) l c h / 0.5);
		transform: translateX(4px);
	}

	.post-preview:hover .post-accent {
		height: 40%;
	}

	.post-preview-content {
		flex: 1;
		min-width: 0;
	}

	.post-preview-meta {
		display: flex;
		align-items: center;
		gap: 0.4rem;
		font-size: 0.78rem;
		color: var(--color-text-muted);
		margin-bottom: 0.35rem;
		font-family: var(--font-mono);
	}

	.separator { opacity: 0.4; }

	h3 {
		font-family: var(--font-serif);
		font-size: 1.15rem;
		margin: 0 0 0.3rem;
		color: var(--color-text);
		line-height: 1.35;
		transition: color var(--duration-fast) var(--ease-smooth);
	}

	.post-preview:hover h3 {
		color: var(--color-accent);
	}

	p {
		font-size: 0.88rem;
		color: var(--color-text-secondary);
		margin: 0;
		line-height: 1.55;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.post-preview-tags {
		display: flex;
		gap: 0.3rem;
		margin-top: 0.5rem;
	}

	.tag {
		font-family: var(--font-mono);
		font-size: 0.65rem;
		font-weight: 500;
		padding: 0.15em 0.5em;
		background: var(--color-accent-subtle);
		border-radius: var(--radius-sm);
		color: var(--color-accent);
	}

	.post-arrow {
		flex-shrink: 0;
		color: var(--color-text-muted);
		opacity: 0;
		transform: translateX(-6px);
		transition: opacity var(--duration-normal) var(--ease-smooth),
			transform var(--duration-normal) var(--ease-spring);
	}

	.post-preview:hover .post-arrow {
		opacity: 1;
		transform: translateX(0);
	}

	@media (max-width: 640px) {
		.post-preview { padding: var(--space-md); }
		.post-arrow { display: none; }
		.post-preview:hover { transform: none; }
	}
</style>
