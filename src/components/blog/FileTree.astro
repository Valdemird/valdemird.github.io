---
interface Props {
	highlight?: string;
}

const { highlight } = Astro.props;
---

<div class="file-tree" data-highlight={highlight}>
	<slot />
</div>

<script>
	function initFileTrees() {
		document.querySelectorAll('.file-tree').forEach((tree) => {
			const highlight = tree.getAttribute('data-highlight');

			// Make folder lines clickable to expand/collapse
			tree.querySelectorAll('.folder').forEach((folder) => {
				const label = folder.querySelector('.folder-label');
				const children = folder.querySelector('.folder-children');
				if (!label || !children) return;

				label.addEventListener('click', () => {
					folder.classList.toggle('collapsed');
				});
			});

			// Highlight matching file
			if (highlight) {
				tree.querySelectorAll('.file').forEach((file) => {
					if (file.textContent?.trim().includes(highlight)) {
						file.classList.add('highlighted');
					}
				});
			}
		});
	}

	initFileTrees();
	document.addEventListener('astro:after-swap', initFileTrees);
</script>

<style>
	.file-tree {
		margin: 1.75em 0;
		padding: 1rem 1.25rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		background: var(--color-bg-secondary);
		font-family: var(--font-mono);
		font-size: 0.82rem;
		line-height: 1.8;
		overflow-x: auto;
	}

	.file-tree :global(.folder-label) {
		cursor: pointer;
		user-select: none;
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		color: var(--color-text);
		font-weight: 500;
		transition: color var(--duration-fast) var(--ease-smooth);
	}

	.file-tree :global(.folder-label:hover) {
		color: var(--color-accent);
	}

	.file-tree :global(.folder-label::before) {
		content: '▼';
		font-size: 0.6em;
		color: var(--color-text-muted);
		transition: transform var(--duration-normal) var(--ease-spring);
		display: inline-block;
		width: 1em;
	}

	.file-tree :global(.folder.collapsed .folder-label::before) {
		transform: rotate(-90deg);
	}

	.file-tree :global(.folder-children) {
		padding-left: 1.25rem;
		border-left: 1px solid var(--color-border);
		margin-left: 0.35rem;
	}

	.file-tree :global(.folder.collapsed .folder-children) {
		display: none;
	}

	.file-tree :global(.file) {
		color: var(--color-text-secondary);
		padding-left: 1.25rem;
		position: relative;
	}

	.file-tree :global(.file::before) {
		content: '📄';
		font-size: 0.75em;
		position: absolute;
		left: 0;
	}

	.file-tree :global(.file.highlighted) {
		color: var(--color-accent);
		font-weight: 600;
		background: var(--color-accent-subtle);
		border-radius: var(--radius-sm);
		padding: 0.05em 0.4em 0.05em 1.25rem;
	}
</style>
