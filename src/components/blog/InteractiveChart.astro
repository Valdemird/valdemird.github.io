---
interface Props {
	type?: 'bar' | 'horizontal';
	title?: string;
	data: { label: string; value: number; color?: string }[];
}

const { type = 'bar', title, data } = Astro.props;
const maxValue = Math.max(...data.map(d => d.value));
const chartId = `chart-${Math.random().toString(36).slice(2, 7)}`;
---

<div class="chart-container" id={chartId}>
	{title && <span class="chart-title">{title}</span>}
	<div class="chart-body">
		{type === 'bar' && (
			<div class="chart-bars">
				{data.map((item, i) => (
					<div class="chart-col">
						<div class="chart-tooltip" aria-hidden="true">
							<strong>{item.value}</strong>
							<span>{item.label}</span>
						</div>
						<div
							class="chart-bar"
							style={`--bar-height: ${(item.value / maxValue) * 100}%; --bar-color: ${item.color || 'var(--color-accent)'}; --bar-delay: ${i * 0.08}s;`}
						></div>
						<span class="chart-label">{item.label}</span>
					</div>
				))}
			</div>
		)}
		{type === 'horizontal' && (
			<div class="chart-rows">
				{data.map((item, i) => (
					<div class="chart-row">
						<span class="chart-row-label">{item.label}</span>
						<div class="chart-row-track">
							<div
								class="chart-row-bar"
								style={`--bar-width: ${(item.value / maxValue) * 100}%; --bar-color: ${item.color || 'var(--color-accent)'}; --bar-delay: ${i * 0.1}s;`}
							></div>
						</div>
						<span class="chart-row-value">{item.value}</span>
					</div>
				))}
			</div>
		)}
	</div>
</div>

<script>
	function initCharts() {
		const observer = new IntersectionObserver((entries) => {
			entries.forEach((entry) => {
				if (entry.isIntersecting) {
					entry.target.classList.add('animate');
					observer.unobserve(entry.target);
				}
			});
		}, { threshold: 0.3 });

		document.querySelectorAll('.chart-container:not(.animate)').forEach((el) => observer.observe(el));
	}

	initCharts();
	document.addEventListener('astro:after-swap', initCharts);
</script>

<style>
	.chart-container {
		margin: 2em 0;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		overflow: hidden;
		background: var(--color-surface);
	}

	.chart-title {
		display: block;
		padding: 0.55rem 1rem;
		font-family: var(--font-mono);
		font-size: 0.75rem;
		font-weight: 500;
		color: var(--color-text-muted);
		border-bottom: 1px solid var(--color-border);
		background: var(--color-bg-secondary);
	}

	.chart-body { padding: 1.5rem; }

	/* ---- Vertical bars ---- */
	.chart-bars {
		display: flex;
		align-items: flex-end;
		gap: 1rem;
		height: clamp(150px, 30vw, 200px);
		padding-top: 2rem;
	}

	.chart-col {
		flex: 1;
		display: flex;
		flex-direction: column;
		align-items: center;
		height: 100%;
		justify-content: flex-end;
		position: relative;
	}

	.chart-bar {
		width: 100%;
		max-width: 48px;
		height: 0;
		background: var(--bar-color);
		border-radius: var(--radius-sm) var(--radius-sm) 0 0;
		transition: height 0.6s var(--ease-spring);
		transition-delay: var(--bar-delay);
		cursor: pointer;
	}

	.chart-container.animate .chart-bar {
		height: var(--bar-height);
	}

	.chart-bar:hover {
		opacity: 0.85;
	}

	.chart-bar:hover + .chart-label,
	.chart-col:hover .chart-tooltip {
		opacity: 1;
	}

	.chart-tooltip {
		position: absolute;
		top: -0.5rem;
		transform: translateY(-100%);
		background: var(--color-text);
		color: var(--color-bg);
		padding: 0.3em 0.6em;
		border-radius: var(--radius-sm);
		font-family: var(--font-mono);
		font-size: 0.7rem;
		white-space: nowrap;
		opacity: 0;
		pointer-events: none;
		transition: opacity var(--duration-fast) var(--ease-smooth);
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.1em;
	}

	.chart-label {
		margin-top: 0.5rem;
		font-family: var(--font-mono);
		font-size: 0.68rem;
		color: var(--color-text-muted);
		text-align: center;
	}

	/* ---- Horizontal bars ---- */
	.chart-rows {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.chart-row {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}

	.chart-row-label {
		font-family: var(--font-mono);
		font-size: 0.75rem;
		color: var(--color-text-secondary);
		min-width: 80px;
		text-align: right;
	}

	.chart-row-track {
		flex: 1;
		height: 24px;
		background: var(--color-bg-secondary);
		border-radius: var(--radius-sm);
		overflow: hidden;
	}

	.chart-row-bar {
		height: 100%;
		width: 0;
		background: var(--bar-color);
		border-radius: var(--radius-sm);
		transition: width 0.8s var(--ease-spring);
		transition-delay: var(--bar-delay);
	}

	.chart-container.animate .chart-row-bar {
		width: var(--bar-width);
	}

	.chart-row-value {
		font-family: var(--font-mono);
		font-size: 0.75rem;
		font-weight: 600;
		color: var(--color-text);
		min-width: 32px;
	}
</style>
