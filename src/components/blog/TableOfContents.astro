---
/**
 * TableOfContents — auto-built TOC from the article's headings.
 *
 * Rendered by the layout (not imported in MDX). Uses the DOM
 * at mount time to discover `h2[id]` and `h3[id]` inside
 * `.article-body`, then binds an IntersectionObserver for scroll-spy.
 *
 * Behavior:
 *  - Hidden when the article has <3 headings.
 *  - Sticky rail on wide viewports (≥1200px).
 *  - Collapsible drawer on narrow viewports, opened by a fixed button.
 *  - Re-initializes on `astro:after-swap`.
 */
interface Props {
	lang?: 'en' | 'es';
}
const { lang = 'en' } = Astro.props;
const label = lang === 'es' ? 'Contenidos' : 'Contents';
const openLabel = lang === 'es' ? 'Índice' : 'Contents';
---

<aside class="toc" data-toc aria-label={label} hidden>
	<div class="toc-label">{label}</div>
	<nav class="toc-nav"><ol class="toc-list" data-toc-list></ol></nav>
</aside>

<button class="toc-drawer-btn" type="button" aria-expanded="false" hidden>
	<svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="12" x2="15" y2="12"></line><line x1="3" y1="18" x2="18" y2="18"></line></svg>
	<span>{openLabel}</span>
</button>

<script>
	const MIN_HEADINGS = 3;

	function buildToc() {
		const aside = document.querySelector<HTMLElement>('[data-toc]');
		const list = document.querySelector<HTMLOListElement>('[data-toc-list]');
		const drawerBtn = document.querySelector<HTMLButtonElement>('.toc-drawer-btn');
		if (!aside || !list || !drawerBtn) return;

		const headings = Array.from(
			document.querySelectorAll<HTMLHeadingElement>('.article-body h2[id], .article-body h3[id]'),
		);

		list.innerHTML = '';

		if (headings.length < MIN_HEADINGS) {
			aside.hidden = true;
			drawerBtn.hidden = true;
			return;
		}

		aside.hidden = false;
		drawerBtn.hidden = false;

		for (const h of headings) {
			const li = document.createElement('li');
			li.className = `toc-item toc-item-${h.tagName.toLowerCase()}`;
			const a = document.createElement('a');
			a.href = `#${h.id}`;
			a.textContent = (h.textContent ?? '').replace(/^#\s*/, '').trim();
			a.dataset.tocLink = h.id;
			li.appendChild(a);
			list.appendChild(li);
		}

		const links = new Map<string, HTMLAnchorElement>();
		for (const a of list.querySelectorAll<HTMLAnchorElement>('a[data-toc-link]')) {
			links.set(a.dataset.tocLink!, a);
		}

		const io = new IntersectionObserver(
			(entries) => {
				for (const entry of entries) {
					const link = links.get(entry.target.id);
					if (!link) continue;
					if (entry.isIntersecting) {
						for (const l of links.values()) l.classList.remove('is-active');
						link.classList.add('is-active');
					}
				}
			},
			{ rootMargin: '-10% 0px -70% 0px', threshold: 0.01 },
		);
		for (const h of headings) io.observe(h);

		// Drawer toggle on narrow viewports
		drawerBtn.addEventListener('click', () => {
			const open = aside.classList.toggle('is-open');
			drawerBtn.setAttribute('aria-expanded', String(open));
		});
		// Close drawer when a link is clicked on mobile
		list.addEventListener('click', (e) => {
			if ((e.target as HTMLElement).tagName === 'A' && window.matchMedia('(max-width: 1199px)').matches) {
				aside.classList.remove('is-open');
				drawerBtn.setAttribute('aria-expanded', 'false');
			}
		});
	}

	function init() {
		// Defer so MDX content is present in the DOM.
		requestAnimationFrame(buildToc);
	}

	init();
	document.addEventListener('astro:after-swap', init);
</script>

<style>
	.toc {
		font-family: var(--font-sans);
	}

	.toc-label {
		font-family: var(--font-mono);
		font-size: 0.68rem;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: var(--color-text-muted);
		margin-bottom: 0.75rem;
	}

	.toc-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
	}

	.toc-item a {
		display: block;
		font-size: 0.85rem;
		line-height: 1.5;
		color: var(--color-text-muted);
		text-decoration: none;
		padding: 0.2rem 0 0.2rem 0.75rem;
		border-left: 2px solid transparent;
		transition: color var(--duration-fast) var(--ease-smooth),
			border-color var(--duration-fast) var(--ease-smooth);
	}

	.toc-item-h3 a {
		padding-left: 1.75rem;
		font-size: 0.8rem;
		color: var(--color-text-muted);
	}

	.toc-item a:hover {
		color: var(--color-text);
	}

	.toc-item a.is-active {
		color: var(--color-accent);
		border-left-color: var(--color-accent);
	}

	/* Wide viewport: sticky rail in the right column. */
	@media (min-width: 1200px) {
		.toc {
			position: sticky;
			top: 5rem;
			max-height: calc(100vh - 6rem);
			overflow-y: auto;
			padding: 0.5rem 0.5rem 1rem;
		}
		.toc-drawer-btn { display: none !important; }
	}

	/* Narrow viewport: hidden drawer toggled by button. */
	@media (max-width: 1199px) {
		.toc {
			position: fixed;
			top: 4.5rem;
			right: 1rem;
			max-width: calc(100vw - 2rem);
			width: 22rem;
			max-height: calc(100vh - 6rem);
			overflow-y: auto;
			padding: 1rem 1.25rem 1.25rem;
			background: var(--color-surface);
			border: 1px solid var(--color-border);
			border-radius: var(--radius-md);
			box-shadow: var(--shadow-lg);
			z-index: 40;
			transform: translateY(-0.5rem);
			opacity: 0;
			pointer-events: none;
			transition: opacity var(--duration-fast) var(--ease-smooth),
				transform var(--duration-fast) var(--ease-smooth);
		}
		.toc.is-open {
			transform: translateY(0);
			opacity: 1;
			pointer-events: auto;
		}
	}

	.toc-drawer-btn {
		position: fixed;
		bottom: 1.25rem;
		right: 1.25rem;
		display: inline-flex;
		align-items: center;
		gap: 0.4em;
		padding: 0.6rem 0.9rem;
		border: 1px solid var(--color-border-strong);
		border-radius: 999px;
		background: var(--color-surface);
		color: var(--color-text);
		font-family: var(--font-mono);
		font-size: 0.75rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		box-shadow: var(--shadow-md);
		cursor: pointer;
		z-index: 39;
		transition: transform var(--duration-normal) var(--ease-spring),
			box-shadow var(--duration-normal) var(--ease-smooth),
			color var(--duration-fast) var(--ease-smooth);
	}
	.toc-drawer-btn:hover {
		transform: translateY(-2px);
		box-shadow: var(--shadow-lg);
		color: var(--color-accent);
	}

	@media (min-width: 1200px) {
		.toc-drawer-btn { display: none; }
	}
</style>
