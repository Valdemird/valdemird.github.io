---
interface Props {
	date: Date;
	locale?: string;
}

const { date, locale = 'en' } = Astro.props;

const localeMap: Record<string, string> = {
	en: 'en-US',
	es: 'es-ES',
};
const resolvedLocale = localeMap[locale] || 'en-US';
---

<time datetime={date.toISOString()}>
	{
		date.toLocaleDateString(resolvedLocale, {
			year: 'numeric',
			month: 'short',
			day: 'numeric',
		})
	}
</time>
