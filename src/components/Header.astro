---
import { SITE_TITLE, getLocale, t } from '../consts';

const locale = getLocale(Astro.url);
const strings = t(Astro.url);
const altLocale = locale === 'en' ? 'es' : 'en';
const altPath = locale === 'en'
	? `/es${Astro.url.pathname}`
	: Astro.url.pathname.replace(/^\/es\/?/, '/');
---

<header id="site-header">
	<nav>
		<a href={locale === 'es' ? '/es/' : '/'} class="logo">
			<span class="logo-text">{SITE_TITLE}</span>
			<span class="logo-dot"></span>
		</a>

		<div class="nav-links">
			<a href={locale === 'es' ? '/es/' : '/'} class:list={[{ active: Astro.url.pathname === '/' || Astro.url.pathname === '/es/' || Astro.url.pathname === '/es' }]}>
				{strings.nav.home}
			</a>
			<a href={locale === 'es' ? '/es/blog/' : '/blog/'} class:list={[{ active: Astro.url.pathname.includes('/blog') }]}>
				{strings.nav.blog}
			</a>
			<a href={locale === 'es' ? '/es/about/' : '/about/'} class:list={[{ active: Astro.url.pathname.includes('/about') }]}>
				{strings.nav.about}
			</a>
		</div>

		<div class="nav-actions">
			<a href={altPath} class="lang-switch" aria-label={`Switch to ${altLocale === 'en' ? 'English' : 'Español'}`}>
				{altLocale === 'en' ? 'EN' : 'ES'}
			</a>

			<button id="theme-toggle" aria-label="Toggle dark mode" type="button">
				<svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<circle cx="12" cy="12" r="5"></circle>
					<line x1="12" y1="1" x2="12" y2="3"></line>
					<line x1="12" y1="21" x2="12" y2="23"></line>
					<line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
					<line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
					<line x1="1" y1="12" x2="3" y2="12"></line>
					<line x1="21" y1="12" x2="23" y2="12"></line>
					<line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
					<line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
				</svg>
				<svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
				</svg>
			</button>

			<button id="menu-toggle" class="menu-toggle" aria-label="Toggle menu" type="button">
				<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<line class="line-1" x1="3" y1="6" x2="21" y2="6"></line>
					<line class="line-2" x1="3" y1="12" x2="21" y2="12"></line>
					<line class="line-3" x1="3" y1="18" x2="21" y2="18"></line>
				</svg>
			</button>
		</div>
	</nav>

	<div id="mobile-nav" class="mobile-nav">
		<a href={locale === 'es' ? '/es/' : '/'}>{strings.nav.home}</a>
		<a href={locale === 'es' ? '/es/blog/' : '/blog/'}>{strings.nav.blog}</a>
		<a href={locale === 'es' ? '/es/about/' : '/about/'}>{strings.nav.about}</a>
	</div>
</header>

<script>
	function initHeader() {
		const toggle = document.getElementById('theme-toggle');
		toggle?.addEventListener('click', () => {
			const current = document.documentElement.getAttribute('data-theme');
			const isDark = current === 'dark' || (!current && window.matchMedia('(prefers-color-scheme: dark)').matches);
			const next = isDark ? 'light' : 'dark';
			document.documentElement.setAttribute('data-theme', next);
			localStorage.setItem('theme', next);
		});

		const menuToggle = document.getElementById('menu-toggle');
		const mobileNav = document.getElementById('mobile-nav');
		menuToggle?.addEventListener('click', () => {
			mobileNav?.classList.toggle('open');
			menuToggle.classList.toggle('open');
		});

		const header = document.getElementById('site-header');
		let ticking = false;
		const onScroll = () => {
			if (!ticking) {
				requestAnimationFrame(() => {
					header?.classList.toggle('scrolled', window.scrollY > 10);
					ticking = false;
				});
				ticking = true;
			}
		};
		window.addEventListener('scroll', onScroll);
		// Set initial state
		header?.classList.toggle('scrolled', window.scrollY > 10);
	}

	initHeader();
	document.addEventListener('astro:after-swap', initHeader);
</script>

<style>
	/* ========================================
	   GLASS NAVBAR — always translucent
	   ======================================== */
	header {
		position: sticky;
		top: 0;
		z-index: 100;
		background: oklch(from var(--color-bg) l c h / 0.65);
		backdrop-filter: blur(16px) saturate(1.4);
		-webkit-backdrop-filter: blur(16px) saturate(1.4);
		border-bottom: 1px solid oklch(from var(--color-border) l c h / 0.4);
		transition: background var(--duration-normal) var(--ease-smooth),
			border-color var(--duration-normal) var(--ease-smooth),
			box-shadow var(--duration-normal) var(--ease-smooth);
	}

	header.scrolled {
		background: oklch(from var(--color-bg) l c h / 0.72);
		border-bottom-color: var(--color-border);
		box-shadow: 0 1px 12px oklch(0 0 0 / 0.04);
	}

	nav {
		max-width: var(--full-width);
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0.65rem 1.5rem;
		gap: 1rem;
	}

	/* Logo with accent dot */
	.logo {
		display: flex;
		align-items: center;
		gap: 0;
		font-family: var(--font-mono);
		font-size: 1rem;
		font-weight: 600;
		color: var(--color-text);
		text-decoration: none;
		letter-spacing: -0.01em;
		transition: opacity var(--duration-fast) var(--ease-smooth);
	}

	.logo:hover {
		opacity: 0.7;
		color: var(--color-text);
	}

	.logo-dot {
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: var(--color-accent);
		margin-left: 2px;
		margin-bottom: -2px;
		transition: transform var(--duration-normal) var(--ease-spring);
	}

	.logo:hover .logo-dot {
		transform: scale(1.5);
	}

	/* Nav links with animated underline */
	.nav-links {
		display: flex;
		gap: 0.15rem;
	}

	.nav-links a {
		position: relative;
		padding: 0.4rem 0.75rem;
		color: var(--color-text-muted);
		text-decoration: none;
		font-size: 0.85rem;
		font-weight: 450;
		border-radius: var(--radius-sm);
		transition: color var(--duration-fast) var(--ease-smooth);
	}

	.nav-links a::after {
		content: '';
		position: absolute;
		bottom: 2px;
		left: 50%;
		width: 0;
		height: 2px;
		background: var(--color-accent);
		border-radius: 1px;
		transition: width var(--duration-normal) var(--ease-spring),
			left var(--duration-normal) var(--ease-spring);
	}

	.nav-links a:hover {
		color: var(--color-text);
	}

	.nav-links a:hover::after {
		width: 60%;
		left: 20%;
	}

	.nav-links a.active {
		color: var(--color-text);
		font-weight: 550;
	}

	.nav-links a.active::after {
		width: 60%;
		left: 20%;
	}

	/* Actions */
	.nav-actions {
		display: flex;
		align-items: center;
		gap: 0.35rem;
	}

	.lang-switch {
		font-family: var(--font-mono);
		font-size: 0.72rem;
		font-weight: 600;
		letter-spacing: 0.06em;
		color: var(--color-text-muted);
		text-decoration: none;
		padding: 0.25rem 0.45rem;
		border: 1px solid oklch(from var(--color-border) l c h / 0.6);
		border-radius: var(--radius-sm);
		transition: all var(--duration-fast) var(--ease-smooth);
	}

	.lang-switch:hover {
		color: var(--color-text);
		border-color: var(--color-border-strong);
		background: oklch(from var(--color-surface) l c h / 0.5);
	}

	#theme-toggle {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 32px;
		height: 32px;
		border: none;
		background: transparent;
		color: var(--color-text-muted);
		cursor: pointer;
		border-radius: var(--radius-sm);
		transition: color var(--duration-fast) var(--ease-smooth),
			transform var(--duration-normal) var(--ease-spring);
	}

	#theme-toggle:hover {
		color: var(--color-text);
		transform: rotate(15deg);
	}

	.icon-moon { display: none; }
	.icon-sun { display: block; }
	[data-theme='dark'] .icon-moon { display: block; }
	[data-theme='dark'] .icon-sun { display: none; }
	@media (prefers-color-scheme: dark) {
		:root:not([data-theme='light']) .icon-moon { display: block; }
		:root:not([data-theme='light']) .icon-sun { display: none; }
	}

	/* Mobile */
	.menu-toggle {
		display: none;
		align-items: center;
		justify-content: center;
		width: 32px;
		height: 32px;
		border: none;
		background: transparent;
		color: var(--color-text-muted);
		cursor: pointer;
		border-radius: var(--radius-sm);
	}

	.mobile-nav {
		display: none;
		flex-direction: column;
		padding: 0 1.5rem 0.75rem;
		gap: 0.15rem;
		background: oklch(from var(--color-bg) l c h / 0.65);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
	}

	.mobile-nav a {
		padding: 0.55rem 0.75rem;
		color: var(--color-text-secondary);
		text-decoration: none;
		font-size: 0.9rem;
		border-radius: var(--radius-sm);
		transition: background var(--duration-fast) var(--ease-smooth),
			color var(--duration-fast) var(--ease-smooth);
	}

	.mobile-nav a:hover {
		background: oklch(from var(--color-accent-subtle) l c h / 0.5);
		color: var(--color-text);
	}

	@media (max-width: 640px) {
		.nav-links { display: none; }
		.menu-toggle { display: flex; }
		.mobile-nav.open { display: flex; }
		.menu-toggle.open .line-1 { transform: rotate(45deg) translate(5px, 5px); }
		.menu-toggle.open .line-2 { opacity: 0; }
		.menu-toggle.open .line-3 { transform: rotate(-45deg) translate(5px, -5px); }
		.menu-toggle line { transition: all var(--duration-normal) var(--ease-smooth); transform-origin: center; }
	}
</style>
